new file mode 100644
index 0000000000000..8681a9c011ac0
--- /dev/null
+++ b/third_party/blink/renderer/platform/chrome_power/chrome_power_fingerprint.cc
@@ -0,0 +1,291 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "third_party/blink/renderer/platform/chrome_power/chrome_power_fingerprint.h"
+
+#include <algorithm>
+#include <cmath>
+#include <cstdint>
+#include <string>
+
+#include "base/base64url.h"
+#include "base/command_line.h"
+#include "base/json/json_reader.h"
+#include "base/no_destructor.h"
+#include "base/strings/string_number_conversions.h"
+
+namespace blink {
+
+namespace {
+
+constexpr char kChromePowerFingerprintSwitch[] = "chrome-power-fingerprint";
+constexpr int kDefaultSeed = 0x4d344d34;
+
+String ToBlinkString(const std::string* value) {
+  return value ? String::FromUtf8(*value) : String();
+}
+
+uint32_t Mix(uint32_t value) {
+  value ^= value >> 16;
+  value *= 0x7feb352dU;
+  value ^= value >> 15;
+  value *= 0x846ca68bU;
+  value ^= value >> 16;
+  return value;
+}
+
+const base::DictValue* DescendDict(
+    const base::DictValue* root,
+    std::initializer_list<std::string_view> path) {
+  const base::DictValue* dict = root;
+  size_t index = 0;
+  const size_t path_size = path.size();
+  for (std::string_view key : path) {
+    if (!dict) {
+      return nullptr;
+    }
+    ++index;
+    if (index == path_size) {
+      return dict;
+    }
+    dict = dict->FindDict(key);
+  }
+  return dict;
+}
+
+}  // namespace
+
+const ChromePowerFingerprint& ChromePowerFingerprint::Get() {
+  static base::NoDestructor<ChromePowerFingerprint> fingerprint;
+  return *fingerprint;
+}
+
+ChromePowerFingerprint::ChromePowerFingerprint() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line->HasSwitch(kChromePowerFingerprintSwitch)) {
+    return;
+  }
+
+  std::string encoded =
+      command_line->GetSwitchValueASCII(kChromePowerFingerprintSwitch);
+  if (encoded.empty()) {
+    return;
+  }
+
+  std::string json;
+  if (!base::Base64UrlDecode(encoded, base::Base64UrlDecodePolicy::IGNORE_PADDING,
+                             &json)) {
+    return;
+  }
+
+  std::optional<base::Value> parsed =
+      base::JSONReader::Read(json, base::JSON_PARSE_RFC);
+  if (!parsed || !parsed->is_dict()) {
+    return;
+  }
+
+  payload_ = std::move(parsed);
+  enabled_ = true;
+}
+
+const base::DictValue* ChromePowerFingerprint::Root() const {
+  return payload_ ? payload_->GetIfDict() : nullptr;
+}
+
+const base::DictValue* ChromePowerFingerprint::DictAt(
+    std::initializer_list<std::string_view> path) const {
+  return DescendDict(Root(), path);
+}
+
+String ChromePowerFingerprint::StringAt(
+    std::initializer_list<std::string_view> path) const {
+  if (path.size() == 0) {
+    return String();
+  }
+  const base::DictValue* dict = DictAt(path);
+  return dict ? ToBlinkString(dict->FindString(*std::prev(path.end())))
+              : String();
+}
+
+std::optional<int> ChromePowerFingerprint::IntAt(
+    std::initializer_list<std::string_view> path) const {
+  if (path.size() == 0) {
+    return std::nullopt;
+  }
+  const base::DictValue* dict = DictAt(path);
+  return dict ? dict->FindInt(*std::prev(path.end())) : std::nullopt;
+}
+
+std::optional<double> ChromePowerFingerprint::DoubleAt(
+    std::initializer_list<std::string_view> path) const {
+  if (path.size() == 0) {
+    return std::nullopt;
+  }
+  const base::DictValue* dict = DictAt(path);
+  return dict ? dict->FindDouble(*std::prev(path.end())) : std::nullopt;
+}
+
+std::optional<bool> ChromePowerFingerprint::BoolAt(
+    std::initializer_list<std::string_view> path) const {
+  if (path.size() == 0) {
+    return std::nullopt;
+  }
+  const base::DictValue* dict = DictAt(path);
+  return dict ? dict->FindBool(*std::prev(path.end())) : std::nullopt;
+}
+
+const base::ListValue* ChromePowerFingerprint::ListAt(
+    std::initializer_list<std::string_view> path) const {
+  if (path.size() == 0) {
+    return nullptr;
+  }
+  const base::DictValue* dict = DictAt(path);
+  return dict ? dict->FindList(*std::prev(path.end())) : nullptr;
+}
+
+Vector<String> ChromePowerFingerprint::Languages() const {
+  Vector<String> languages;
+  const base::ListValue* list = ListAt({"languages"});
+  if (!list) {
+    return languages;
+  }
+  languages.ReserveInitialCapacity(static_cast<wtf_size_t>(list->size()));
+  for (const auto& value : *list) {
+    const std::string* language = value.GetIfString();
+    if (language && !language->empty()) {
+      languages.push_back(String::FromUtf8(*language));
+    }
+  }
+  return languages;
+}
+
+int ChromePowerFingerprint::CanvasNoiseSeed() const {
+  return IntAt({"noise", "canvas"}).value_or(
+      IntAt({"canvasSeed"}).value_or(kDefaultSeed));
+}
+
+int ChromePowerFingerprint::AudioNoiseSeed() const {
+  return IntAt({"noise", "audio"}).value_or(
+      IntAt({"audioSeed"}).value_or(kDefaultSeed));
+}
+
+int ChromePowerFingerprint::WebGLNoiseSeed() const {
+  return IntAt({"noise", "webgl"}).value_or(
+      IntAt({"canvasSeed"}).value_or(kDefaultSeed));
+}
+
+uint32_t ChromePowerFingerprint::StableByte(size_t index, int seed) const {
+  uint32_t value = static_cast<uint32_t>(seed);
+  return Mix(value ^ static_cast<uint32_t>(index * 2654435761U)) & 0xffU;
+}
+
+void ChromePowerFingerprint::PerturbPixels(base::span<uint8_t> data,
+                                           int channels) const {
+  PerturbPixelsWithSeed(data, channels, CanvasNoiseSeed());
+}
+
+void ChromePowerFingerprint::PerturbWebGLPixels(base::span<uint8_t> data,
+                                                int channels) const {
+  PerturbPixelsWithSeed(data, channels, WebGLNoiseSeed());
+}
+
+void ChromePowerFingerprint::PerturbPixelsWithSeed(base::span<uint8_t> data,
+                                                   int channels,
+                                                   int seed) const {
+  if (!enabled_ || data.empty() || channels <= 0) {
+    return;
+  }
+
+  for (size_t offset = 0; offset + static_cast<size_t>(channels) <= data.size();
+       offset += static_cast<size_t>(channels)) {
+    const uint32_t noise = StableByte(offset / channels, seed);
+    if ((noise & 0x07U) != 0) {
+      continue;
+    }
+    const int channel = static_cast<int>((noise >> 3) % std::min(channels, 3));
+    const int delta = (noise & 0x10U) ? 1 : -1;
+    int value = static_cast<int>(data[offset + channel]) + delta;
+    data[offset + channel] = static_cast<uint8_t>(std::clamp(value, 0, 255));
+  }
+}
+
+void ChromePowerFingerprint::PerturbFloats(base::span<float> data) const {
+  if (!enabled_ || data.empty()) {
+    return;
+  }
+
+  const int seed = AudioNoiseSeed();
+  for (size_t i = 0; i < data.size(); ++i) {
+    const uint32_t noise =
+        Mix(static_cast<uint32_t>(seed) ^ static_cast<uint32_t>(i));
+    if ((noise & 0x0fU) != 0) {
+      continue;
+    }
+    const float delta = (noise & 0x10U) ? 1.0e-7f : -1.0e-7f;
+    data[i] = std::round(data[i] * 1000000.0f) / 1000000.0f + delta;
+  }
+}
+
+String ChromePowerFingerprint::MediaDeviceId(std::string_view kind,
+                                             wtf_size_t index) const {
+  const base::ListValue* devices = ListAt({"mediaDevices"});
+  if (!devices) {
+    return String();
+  }
+  wtf_size_t seen = 0;
+  for (const auto& value : *devices) {
+    const base::DictValue* dict = value.GetIfDict();
+    const std::string* device_kind = dict ? dict->FindString("kind") : nullptr;
+    if (!device_kind || *device_kind != kind) {
+      continue;
+    }
+    if (seen++ == index) {
+      return ToBlinkString(dict->FindString("deviceId"));
+    }
+  }
+  return String();
+}
+
+String ChromePowerFingerprint::MediaDeviceGroupId(std::string_view kind,
+                                                  wtf_size_t index) const {
+  const base::ListValue* devices = ListAt({"mediaDevices"});
+  if (!devices) {
+    return String();
+  }
+  wtf_size_t seen = 0;
+  for (const auto& value : *devices) {
+    const base::DictValue* dict = value.GetIfDict();
+    const std::string* device_kind = dict ? dict->FindString("kind") : nullptr;
+    if (!device_kind || *device_kind != kind) {
+      continue;
+    }
+    if (seen++ == index) {
+      return ToBlinkString(dict->FindString("groupId"));
+    }
+  }
+  return String();
+}
+
+String ChromePowerFingerprint::MediaDeviceLabel(std::string_view kind,
+                                                wtf_size_t index) const {
+  const base::ListValue* devices = ListAt({"mediaDevices"});
+  if (!devices) {
+    return String();
+  }
+  wtf_size_t seen = 0;
+  for (const auto& value : *devices) {
+    const base::DictValue* dict = value.GetIfDict();
+    const std::string* device_kind = dict ? dict->FindString("kind") : nullptr;
+    if (!device_kind || *device_kind != kind) {
+      continue;
+    }
+    if (seen++ == index) {
+      return ToBlinkString(dict->FindString("label"));
+    }
+  }
+  return String();
+}
+
+}  // namespace blink
